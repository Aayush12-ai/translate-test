# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
MONGODB_URI=mongodb://localhost:27017/translate-test

# Server Ports
API_PORT=18080
WEB_PORT=22042

# Authentication & Security
JWT_SECRET=your-secret-key-change-this-in-production
ADMIN_KEY=1234
ADMIN_EMAIL=your-admin-email@gmail.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:18080/api/auth/google/callback

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@translateapp.com

# API Configuration
API_BASE_URL=http://localhost:18080
FRONTEND_URL=http://localhost:22042

# Translator Configuration
# Optional but recommended for the homepage image-analysis assistant.
GROQ_API_KEY=
# Optional. Defaults to a Groq multimodal model that can analyze images.
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Required for live translated subtitles.
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
# Optional for global Translator resources. Required for regional or multi-service resources.
AZURE_TRANSLATOR_REGION=
# Optional. Use this if you have a deployed Custom Translator category/model.
AZURE_TRANSLATOR_CATEGORY=

# Legacy fallback if you still want to use LibreTranslate instead of Azure.
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

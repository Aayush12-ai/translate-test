DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
# Optional. Leave these out if you want start-local.cmd to auto-pick free ports.
API_PORT=18080
WEB_PORT=22042
# Required for live translated subtitles.
# For a global Translator resource, the default endpoint usually works as-is.
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
# Optional for global Translator resources. Required for regional or multi-service resources.
AZURE_TRANSLATOR_REGION=
# Optional. Use this if you have a deployed Custom Translator category/model.
AZURE_TRANSLATOR_CATEGORY=

# Legacy fallback if you still want to use LibreTranslate instead of Azure.
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=


